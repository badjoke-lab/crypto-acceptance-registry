{
  "name": "crypto-acceptance-registry",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:normalized-candidates": "tsx scripts/build-normalized-candidates.ts",
    "build:classified-candidates": "tsx scripts/build-classified-candidates.ts",
    "build:public-artifacts": "tsx scripts/build-public-artifacts.ts",
    "build:product-merchants": "tsx scripts/build-product-merchants.ts",
    "build:review-queue": "tsx scripts/build-review-queue.ts",
    "build:product-stats": "tsx scripts/build-product-stats.ts",
    "build:cutover-report": "tsx scripts/build-cutover-report.ts",
    "audit:registry-quality": "tsx scripts/audit-registry-quality.ts",
    "embed:public-artifacts": "tsx scripts/embed-public-artifacts.ts",
    "check:public-health": "tsx scripts/assert-public-stats-health.ts",
    "verify:public-artifacts": "pnpm run build:public-artifacts && pnpm run embed:public-artifacts && pnpm run check:public-health && pnpm run build",
    "release:public": "pnpm run build:public-artifacts && pnpm run embed:public-artifacts && pnpm run check:public-health && opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "next": "^16.2.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.3",
    "@types/node": "25.6.0",
    "@types/pg": "^8.15.6",
    "@types/react": "19.2.14"
  }
}
